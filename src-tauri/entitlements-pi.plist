<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the bundled `pi` sidecar
  (Contents/Resources/pi-install/pi), a Bun-compiled single-file executable that
  JITs JavaScript and dlopen()s third-party native `.node` modules at runtime.

  Without these, a notarized (hardened-runtime) build crashes the sidecar on
  launch — the agent comes up with zero tools, or pi exits immediately.

  - allow-jit / allow-unsigned-executable-memory: Bun's JS engine JITs.
  - disable-library-validation: load `.node` modules not signed by our Team ID.
  - allow-dyld-environment-variables: pi/bun honor DYLD_* at spawn.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
