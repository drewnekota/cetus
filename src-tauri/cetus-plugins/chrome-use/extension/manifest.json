{
  "manifest_version": 3,
  "name": "Cetus Chrome Use",
  "version": "0.1.0",
  "key": "",
  "description": "Connect Cetus to the user's real Chrome tabs after explicit approval.",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Cetus Chrome Use",
    "default_popup": "popup.html"
  }
}
