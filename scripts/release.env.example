# Local RELEASE signing/notarization config — COPY to scripts/release.env
# (gitignored) and fill in. Used by scripts/build-release.sh.
#
# Unlike scripts/signing.env (local dev, Apple Development identity), this uses
# your DEVELOPER ID identity — the same one CI signs releases with — so a local
# build matches what users download.
#
# NEVER commit scripts/release.env or any real credential.

APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Only needed when running with --notarize:
APPLE_ID="your-apple-developer-email@example.com"
APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # app-specific password (appleid.apple.com), NOT your login password
APPLE_TEAM_ID="TEAMID"
